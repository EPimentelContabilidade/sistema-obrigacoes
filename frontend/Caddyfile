:80 {
    root * /app/dist
    encode gzip

    handle /api/* {
        reverse_proxy https://sistema-obrigacoes-production.up.railway.app {
            header_up Host sistema-obrigacoes-production.up.railway.app
            header_up X-Real-IP {remote_host}
        }
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
