:80 {
    root * /app/dist
    encode gzip

    # Proxy /api/* para o backend FastAPI
    reverse_proxy /api/* https://sistema-obrigacoes-production.up.railway.app {
        header_up Host sistema-obrigacoes-production.up.railway.app
        header_up X-Forwarded-Proto https
    }

    # SPA: qualquer rota não encontrada retorna index.html
    try_files {path} /index.html
    file_server
}
